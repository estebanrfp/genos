{
  "name": "genosos",
  "version": "1.0.0",
  "description": "Your private AI assistant — across every channel",
  "keywords": [
    "ai",
    "ai-agent",
    "ai-assistant",
    "ai-gateway",
    "assistant",
    "bun",
    "chatbot",
    "discord",
    "encrypted",
    "imessage",
    "llm",
    "multi-channel",
    "private",
    "self-hosted",
    "slack",
    "telegram",
    "voice",
    "whatsapp"
  ],
  "homepage": "https://github.com/estebanrfp/genos#readme",
  "bugs": {
    "url": "https://github.com/estebanrfp/genos/issues"
  },
  "license": "MIT",
  "author": "Esteban Fuster Pozzi (@estebanrfp)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/estebanrfp/genos.git"
  },
  "bin": {
    "genosos": "genosos.mjs"
  },
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "genosos.mjs",
    "genosos.png",
    "README.md",
    "assets/",
    "src/",
    "docs/",
    "extensions/",
    "skills/"
  ],
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./plugin-sdk": "./src/plugin-sdk/index.js",
    "./plugin-sdk/account-id": "./src/plugin-sdk/account-id.js",
    "./cli-entry": "./genosos.mjs"
  },
  "scripts": {
    "build": "bun scripts/copy-hook-metadata.js && bun scripts/copy-export-html-templates.js && bun scripts/write-build-info.js",
    "check": "pnpm format:check && pnpm lint",
    "dev": "bun --watch src/entry.js",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "gateway:dev": "GENOS_SKIP_CHANNELS=1 bun src/entry.js --dev gateway",
    "gateway:watch": "bun --watch src/entry.js gateway --force",
    "genosos": "bun src/entry.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix && pnpm format",
    "prepare": "command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath git-hooks || exit 0",
    "setup": "pnpm install && pnpm build && pnpm ui:build",
    "start": "bun src/entry.js",
    "test": "bun scripts/test-parallel.mjs",
    "test:coverage": "bunx vitest run --config vitest.unit.config.js --coverage",
    "test:e2e": "bunx vitest run --config vitest.e2e.config.js",
    "test:fast": "bunx vitest run --config vitest.unit.config.js",
    "test:watch": "vitest",
    "ui:build": "bun scripts/ui.js build",
    "ui:dev": "bun scripts/ui.js dev",
    "ui:install": "bun scripts/ui.js install"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.14.1",
    "@aws-sdk/client-bedrock": "^3.992.0",
    "@buape/carbon": "0.14.0",
    "@clack/prompts": "^1.0.1",
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "@homebridge/ciao": "^1.3.5",
    "@line/bot-sdk": "^10.6.0",
    "@lydell/node-pty": "1.2.0-beta.3",
    "@mariozechner/pi-agent-core": "0.53.0",
    "@mariozechner/pi-ai": "0.53.0",
    "@mariozechner/pi-coding-agent": "0.53.0",
    "@mariozechner/pi-tui": "0.53.0",
    "@mozilla/readability": "^0.6.0",
    "@simplewebauthn/server": "13.2.2",
    "@sinclair/typebox": "0.34.48",
    "@slack/bolt": "^4.6.0",
    "@slack/web-api": "^7.14.1",
    "@toon-format/toon": "2.1.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "ajv": "^8.18.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cli-highlight": "^2.1.11",
    "commander": "^14.0.3",
    "croner": "^10.0.1",
    "discord-api-types": "^0.38.39",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "file-type": "^21.3.0",
    "grammy": "^1.40.0",
    "https-proxy-agent": "^7.0.6",
    "jiti": "^2.6.1",
    "json5": "^2.2.3",
    "jszip": "^3.10.1",
    "linkedom": "^0.18.12",
    "long": "^5.3.2",
    "markdown-it": "^14.1.1",
    "node-edge-tts": "^1.2.10",
    "osc-progress": "^0.3.0",
    "pdfjs-dist": "^5.4.624",
    "playwright-core": "1.58.2",
    "proper-lockfile": "^4.1.2",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.34.5",
    "signal-utils": "^0.21.1",
    "sqlite-vec": "0.1.7-alpha.2",
    "tar": "7.5.9",
    "tslog": "^4.10.2",
    "undici": "^7.22.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "oxfmt": "0.33.0",
    "oxlint": "^1.48.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@napi-rs/canvas": "^0.1.89",
    "node-llama-cpp": "3.15.1"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "packageManager": "pnpm@10.23.0",
  "pnpm": {
    "minimumReleaseAge": 2880,
    "overrides": {
      "fast-xml-parser": "5.3.4",
      "form-data": "2.5.4",
      "qs": "6.14.2",
      "@sinclair/typebox": "0.34.48",
      "tar": "7.5.9",
      "tough-cookie": "4.1.3"
    },
    "onlyBuiltDependencies": [
      "@lydell/node-pty",
      "@matrix-org/matrix-sdk-crypto-nodejs",
      "@napi-rs/canvas",
      "@whiskeysockets/baileys",
      "authenticate-pam",
      "esbuild",
      "node-llama-cpp",
      "protobufjs",
      "sharp"
    ]
  }
}
