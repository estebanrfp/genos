# GenosOS .env example
#
# Quick start:
# 1) Copy this file to `.env` (for local runs) or `~/.genosv1/.env` (for daemons)
# 2) Fill only the values you use
# 3) Keep real secrets out of git
#
# Most configuration is done conversationally — just talk to your agent.
# This file is for advanced deployments or non-macOS systems without Keychain.

# -----------------------------------------------------------------------------
# Vault passphrase (required on Linux/Windows — macOS uses Keychain)
# -----------------------------------------------------------------------------
VAULT_PASSPHRASE=change-me-to-a-strong-passphrase

# -----------------------------------------------------------------------------
# Gateway auth (recommended if binding beyond loopback)
# -----------------------------------------------------------------------------
GENOS_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Generate one: openssl rand -hex 32

# -----------------------------------------------------------------------------
# AI providers (set at least one — or configure via conversation)
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable — or configure via conversation)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
